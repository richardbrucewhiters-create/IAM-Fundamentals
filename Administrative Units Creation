# Create 5 Administrative Units
$departments = @("Finance", "Sales", "IT", "Operations", "Clinical")

#Loop through the list and create a DisplayName and Description for each $dept entry
foreach ($dept in $departments) {
    $params = @{
        DisplayName = "$dept AU"
        Description = "Administrative unit for $dept department"
    }
#create the AU with the above parameters
    New-MgDirectoryAdministrativeUnit -BodyParameter $params
}
